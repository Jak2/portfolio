---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';
import { Content, getHeadings } from '../data/portfolio.md';

// Build sidebar tree: H2 as collapsible parents, H3 as children
type NavChild = { depth: number; slug: string; text: string };
type NavSection = NavChild & { children: NavChild[] };

const headings = getHeadings();
const sidebarTree: NavSection[] = headings
  .filter((h) => h.depth === 2 || h.depth === 3)
  .reduce<NavSection[]>((tree, h) => {
    if (h.depth === 2) {
      tree.push({ ...h, children: [] });
    } else if (h.depth === 3 && tree.length > 0) {
      tree[tree.length - 1].children.push(h);
    }
    return tree;
  }, []);
---

<Layout>
  <!-- ── Topbar ── -->
  <header class="topbar">
    <div style="display:flex;align-items:center;gap:0.75rem;">
      <button class="menu-btn" id="menuBtn" aria-label="Toggle menu">☰</button>
      <span class="topbar-name">JAK<span>.</span>T</span>
    </div>

    <div class="topbar-controls">
      <!-- 4 theme dots -->
      <button class="theme-dot active" data-t="amber" aria-label="Amber theme" title="Amber"></button>
      <button class="theme-dot" data-t="sage"  aria-label="Sage theme"  title="Sage"></button>
      <button class="theme-dot" data-t="slate" aria-label="Slate theme" title="Slate"></button>
      <button class="theme-dot" data-t="rose"  aria-label="Rose theme"  title="Rose"></button>

      <!-- Dark / light toggle -->
      <button class="dark-toggle" id="darkToggle" aria-label="Toggle dark mode">◐ Dark</button>
    </div>
  </header>

  <!-- Mobile overlay -->
  <div class="sidebar-overlay" id="sidebarOverlay"></div>

  <!-- ── Sidebar ── -->
  <nav class="sidebar" id="sidebar" aria-label="Page navigation">
    <div class="sidebar-label">Navigation</div>

    {sidebarTree.map((section) => (
      <div class="nav-section" data-slug={section.slug}>
        {section.children.length > 0 ? (
          <>
            <button class="nav-h2" data-target={section.slug} aria-expanded="false">
              {section.text}
              <span class="nav-arrow">▶</span>
            </button>
            <div class="nav-children" role="list">
              {section.children.map((child) => (
                <a class="nav-h3" href={`#${child.slug}`} role="listitem">
                  {child.text}
                </a>
              ))}
            </div>
          </>
        ) : (
          <a class="nav-h2" href={`#${section.slug}`} style="text-decoration:none;">
            {section.text}
            <span></span>
          </a>
        )}
      </div>
    ))}
  </nav>

  <!-- ── Main Content ── -->
  <main class="main-content">
    <div class="prose" id="prose-content">
      <Content /> <!-- 👈 This is where Astro drops in parsed Markdown -->
    </div>
  </main>
</Layout>

<script>
  /* ───────────────────────────────────────────────
     Theme switcher
  ─────────────────────────────────────────────── */
  const html = document.documentElement;

  function setTheme(t: string) {
    html.setAttribute('data-theme', t);
    localStorage.setItem('theme', t);
    document.querySelectorAll('.theme-dot').forEach((el) => {
      el.classList.toggle('active', (el as HTMLElement).dataset.t === t);
    });
  }

  document.querySelectorAll('.theme-dot').forEach((btn) => {
    btn.addEventListener('click', () => {
      setTheme((btn as HTMLElement).dataset.t!);
    });
  });

  // Restore active dot on load
  const currentTheme = html.getAttribute('data-theme') || 'amber';
  document.querySelectorAll('.theme-dot').forEach((el) => {
    el.classList.toggle('active', (el as HTMLElement).dataset.t === currentTheme);
  });

  /* ───────────────────────────────────────────────
     Dark mode toggle
  ─────────────────────────────────────────────── */
  const darkBtn = document.getElementById('darkToggle')!;

  function updateDarkBtn() {
    const isDark = html.getAttribute('data-mode') === 'dark';
    darkBtn.textContent = isDark ? '○ Light' : '◐ Dark';
  }

  updateDarkBtn();

  darkBtn.addEventListener('click', () => {
    const isDark = html.getAttribute('data-mode') === 'dark';
    const next = isDark ? 'light' : 'dark';
    html.setAttribute('data-mode', next);
    localStorage.setItem('mode', next);
    updateDarkBtn();
  });

  /* ───────────────────────────────────────────────
     Sidebar: collapse / expand sections
  ─────────────────────────────────────────────── */
  document.querySelectorAll('.nav-section').forEach((section) => {
    const btn = section.querySelector('.nav-h2[data-target]') as HTMLButtonElement | null;
    if (!btn) return;

    btn.addEventListener('click', () => {
      const isOpen = section.classList.toggle('open');
      btn.setAttribute('aria-expanded', String(isOpen));
      // Smooth scroll to section heading
      const slug = btn.dataset.target!;
      const target = document.getElementById(slug);
      if (target) target.scrollIntoView({ behavior: 'smooth', block: 'start' });
    });
  });

  /* ───────────────────────────────────────────────
     Smooth scroll for H3 nav links
  ─────────────────────────────────────────────── */
  document.querySelectorAll('.nav-h3').forEach((link) => {
    link.addEventListener('click', (e) => {
      e.preventDefault();
      const href = (link as HTMLAnchorElement).getAttribute('href')!;
      const id = href.slice(1);
      const target = document.getElementById(id);
      if (target) target.scrollIntoView({ behavior: 'smooth', block: 'start' });
      // Close sidebar on mobile
      if (window.innerWidth <= 768) closeSidebar();
    });
  });

  /* ───────────────────────────────────────────────
     Active section highlight (IntersectionObserver)
  ─────────────────────────────────────────────── */
  const allNavLinks = document.querySelectorAll('.nav-h2[href], .nav-h3');

  function setActiveLink(slug: string) {
    allNavLinks.forEach((link) => {
      const href = (link as HTMLAnchorElement).getAttribute('href');
      const isActive = href === `#${slug}`;
      link.classList.toggle('active', isActive);

      // If a h3 is active, open its parent section
      if (isActive && link.classList.contains('nav-h3')) {
        link.closest('.nav-section')?.classList.add('open');
      }
    });
  }

  const headingEls = document.querySelectorAll<HTMLElement>(
    '.prose h2, .prose h3'
  );

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          setActiveLink(entry.target.id);
        }
      });
    },
    { rootMargin: '-60px 0px -60% 0px', threshold: 0 }
  );

  headingEls.forEach((el) => observer.observe(el));

  /* ───────────────────────────────────────────────
     Mobile sidebar toggle
  ─────────────────────────────────────────────── */
  const menuBtn    = document.getElementById('menuBtn')!;
  const sidebar    = document.getElementById('sidebar')!;
  const overlay    = document.getElementById('sidebarOverlay')!;

  function openSidebar()  { sidebar.classList.add('open');  overlay.classList.add('open'); }
  function closeSidebar() { sidebar.classList.remove('open'); overlay.classList.remove('open'); }

  menuBtn.addEventListener('click', () => {
    sidebar.classList.contains('open') ? closeSidebar() : openSidebar();
  });
  overlay.addEventListener('click', closeSidebar);

  /* ───────────────────────────────────────────────
     Hero card: wrap the first H1 + meta in a card
  ─────────────────────────────────────────────── */
  const prose = document.getElementById('prose-content');
  if (prose) {
    const h1 = prose.querySelector('h1');
    if (h1) {
      const card = document.createElement('div');
      card.className = 'hero-card';
      // Collect all nodes up to first HR or H2
      const nodes: Node[] = [];
      let node = h1 as Node;
      while (node) {
        const next = node.nextSibling;
        if ((node as Element).tagName === 'HR' || (node as Element).tagName === 'H2') break;
        nodes.push(node);
        node = next!;
      }
      h1.parentNode?.insertBefore(card, h1);
      nodes.forEach((n) => card.appendChild(n));
    }
  }
</script>
